#QUESTION03
import math
total_cost = 1000000
down_payment = total_cost * 0.25
semi_annual_raise = 0.07
r = 0.04

annual_salary = float(input("Enter annual salary: "))

epsilon = 100  # allowed error
months = 36

low = 0
high = 1
guess = (high + low) / 2

steps = 0

def simulate(portion_saved):
    global annual_salary
    current_savings = 0
    monthly_salary = annual_salary / 12

    temp_salary = annual_salary

    for m in range(1, months + 1):

        current_savings += current_savings * (r / 12)
        current_savings += monthly_salary * portion_saved

        if m % 6 == 0:
            temp_salary += temp_salary * semi_annual_raise
            monthly_salary = temp_salary / 12

    return current_savings

# check if even possible
if simulate(1) < down_payment:
    print("It is not possible to pay the down payment in three years.")
else:

    while True:
        steps += 1
        result = simulate(guess)

        if abs(result - down_payment) <= epsilon:
            break

        if result < down_payment:
            low = guess
        else:
            high = guess

        guess = (low + high) / 2
        print("Best savings rate:", round(guess, 4))
        print("Steps in bisection search:", steps)




